<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        CVE-2026-22747, CVE-2026-22754, CVE-2026-22753 — Spring Security 7.0.4
        Pas de version corrigée disponible sur Maven Central au 2026-04-27.
        Risque atténué par les contrôles suivants :
          - Nginx reverse proxy avec headers sécurité (HSTS, X-Frame-Options, CSP)
          - Pattern BFF : les tokens OAuth2 ne transitent jamais côté client
          - Network Policies Kubernetes : egress Internet bloqué, isolation inter-pods
          - Keycloak IAM : authentification et autorisation centralisées
        À retirer dès que Spring Security 7.0.5+ est disponible.
    -->
    <suppress>
        <notes>CVE-2026-22747 : Spring Security 7.0.4 - pas de fix disponible. Risque atténué par Nginx, BFF, Network Policies K8s, Keycloak. A retirer avec Spring Security 7.0.5+.</notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.security/.*@7\.0\.4$</packageUrl>
        <cve>CVE-2026-22747</cve>
    </suppress>

    <suppress>
        <notes>CVE-2026-22754 : Spring Security 7.0.4 - pas de fix disponible. Risque atténué par Nginx, BFF, Network Policies K8s, Keycloak. A retirer avec Spring Security 7.0.5+.</notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.security/.*@7\.0\.4$</packageUrl>
        <cve>CVE-2026-22754</cve>
    </suppress>

    <suppress>
        <notes>CVE-2026-22753 : Spring Security 7.0.4 - pas de fix disponible. Risque atténué par Nginx, BFF, Network Policies K8s, Keycloak. A retirer avec Spring Security 7.0.5+.</notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.security/.*@7\.0\.4$</packageUrl>
        <cve>CVE-2026-22753</cve>
    </suppress>


    <!--
        CVE-2026-41240, CVE-2026-41238, CVE-2026-41239, GHSA-39q2-94rc-95cp — DOMPurify 3.3.2 dans swagger-ui
        DOMPurify < 3.4.0 embarqué dans swagger-ui-5.32.2.jar (springdoc-openapi 3.0.3, dernière version disponible).
        CVE-2026-41240 (NVD, CVSS 6.1) : XSS bypass via FORBID_TAGS + ADD_TAGS function-based — corrigé dans DOMPurify 3.4.0.
        CVE-2026-41238, CVE-2026-41239, GHSA-39q2-94rc-95cp (RetireJS) : autres vecteurs XSS dans DOMPurify 3.3.2.
        Risque atténué par les contrôles suivants :
          - Swagger UI accessible uniquement aux utilisateurs authentifiés (Spring Security)
          - XSS requiert interaction utilisateur ET contrôle du contenu affiché dans Swagger UI
          - CVSS modifié MAV:A (vecteur adjacent) dans le contexte projet
        À retirer dès que springdoc-openapi 3.0.4+ embarque DOMPurify >= 3.4.0.
    -->
    <suppress>
        <notes>CVE-2026-41240 : DOMPurify 3.3.2 dans swagger-ui — pas de springdoc fix disponible. Swagger UI protégé par Spring Security. A retirer avec springdoc 3.0.4+.</notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@3\.3\.2$</packageUrl>
        <cve>CVE-2026-41240</cve>
    </suppress>

    <suppress>
        <notes>CVE-2026-41238 (RetireJS) : DOMPurify 3.3.2 dans swagger-ui — pas de springdoc fix disponible. Swagger UI protégé par Spring Security. A retirer avec springdoc 3.0.4+.</notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@3\.3\.2$</packageUrl>
        <vulnerabilityName>CVE-2026-41238</vulnerabilityName>
    </suppress>

    <suppress>
        <notes>CVE-2026-41239 (RetireJS) : DOMPurify 3.3.2 dans swagger-ui — pas de springdoc fix disponible. Swagger UI protégé par Spring Security. A retirer avec springdoc 3.0.4+.</notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@3\.3\.2$</packageUrl>
        <vulnerabilityName>CVE-2026-41239</vulnerabilityName>
    </suppress>

    <suppress>
        <notes>GHSA-39q2-94rc-95cp (RetireJS/GHSA) : DOMPurify 3.3.2 dans swagger-ui — pas de springdoc fix disponible. Swagger UI protégé par Spring Security. A retirer avec springdoc 3.0.4+.</notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@3\.3\.2$</packageUrl>
        <vulnerabilityName>GHSA-39q2-94rc-95cp</vulnerabilityName>
    </suppress>

</suppressions>
