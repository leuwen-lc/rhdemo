        stage('🔒 Démarrage OWASP ZAP Proxy') {
            when {
                expression { params.RUN_SELENIUM_TESTS == true }
            }
            steps {
                script {
                    echo '▶ Démarrage du proxy OWASP ZAP pour analyse de sécurité...'
                    echo '   Le trafic Selenium sera intercepté et analysé par ZAP'
                }

                sh """#!/bin/bash
                    # Utiliser la clé API ZAP définie comme variable d'environnement Jenkins
                    echo "🔐 Utilisation de ZAP_API_KEY: ${env.ZAP_API_KEY.take(8)}..."

                    # IMPORTANT: ZAP est maintenant dans l'environnement Jenkins, pas ephemere
                    cd rhDemo/infra/jenkins-docker

                    # Nettoyage : supprimer le conteneur ZAP existant s'il existe
                    if docker ps -a --format '{{.Names}}' | grep -q '^rhdemo-jenkins-zap\$'; then
                        echo "🧹 Suppression du conteneur ZAP existant..."
                        docker stop rhdemo-jenkins-zap 2>/dev/null || true
                        docker rm rhdemo-jenkins-zap 2>/dev/null || true
                        echo "✅ Conteneur ZAP supprimé"
                    fi

                    # Démarrage d'un nouveau conteneur ZAP avec la clé API correcte
                    echo "🚀 Démarrage d'un nouveau conteneur ZAP..."
                    echo "   Réseau: rhdemo-jenkins-network"
                    echo "   Clé API: ${env.ZAP_API_KEY.take(8)}..."
                    ZAP_API_KEY=${env.ZAP_API_KEY} docker-compose -f docker-compose.yml -f docker-compose.zap.yml up -d owasp-zap

                    echo "⏳ Attente du démarrage de ZAP (60s max)..."
                    echo "   (ZAP doit charger ses add-ons, créer le certificat CA, etc.)"
                    timeout=120
                    attempt=0
                    while [ \$timeout -gt 0 ]; do
                        attempt=\$((attempt + 1))
                        if docker exec rhdemo-jenkins-zap curl -f http://localhost:8090/JSON/core/view/version/?apikey=${env.ZAP_API_KEY} >/dev/null 2>&1; then
                            echo "✅ ZAP démarré et accessible (après \$((120 - timeout))s)"
                            break
                        fi
                        if [ \$((attempt % 5)) -eq 0 ]; then
                            echo "   Attente... (\$((120 - timeout))s écoulées, reste \${timeout}s)"
                        fi
                        sleep 2
                        timeout=\$((timeout - 2))
                    done

                    if [ \$timeout -le 0 ]; then
                        echo "❌ Timeout: ZAP n'est pas prêt après 60s"
                        echo "📋 Derniers logs de ZAP:"
                        docker logs --tail=50 rhdemo-jenkins-zap
                        exit 1
                    fi

                    echo "📊 ZAP Status:"
                    docker exec rhdemo-jenkins-zap curl -s http://localhost:8090/JSON/core/view/version/?apikey=${env.ZAP_API_KEY} | jq .

                    echo ""
                    echo "🔗 Connexion de ZAP au réseau ephemere..."
                    docker network connect rhdemo-ephemere-network rhdemo-jenkins-zap 2>/dev/null || echo "⚠️  ZAP déjà connecté au réseau ephemere"

                    echo ""
                    echo "✅ OWASP ZAP prêt à intercepter le trafic Selenium"
                    echo "   Container: rhdemo-jenkins-zap"
                    echo "   Réseau 1: rhdemo-jenkins-network (API + Proxy)"
                    echo "   Réseau 2: rhdemo-ephemere-network (accès application via connexion dynamique)"
                    echo "   Port unique (API + Proxy): owasp-zap:8090"
                """
            }
        }

        stage('🧪 Tests Selenium') {
            when {
                expression { params.RUN_SELENIUM_TESTS == true }
            }
            steps {
                script {
                    echo "▶ Exécution des tests Selenium avec proxy ZAP..."
                }

                dir(env.TEST_PROJECT_PATH) {
                    sh """
                        # Source les secrets pour les tests (depuis /tmp, hors workspace)
                        set +x
                        . ${SECRETS_ENV_VARS}

                        # URLs via nginx avec HTTPS
                        # Depuis que nginx écoute aussi sur le port 58443 en interne (réseau Docker),
                        # Selenium/ZAP peuvent utiliser directement les mêmes URLs que les utilisateurs externes:
                        # rhdemo.ephemere.local:58443 et keycloak.ephemere.local:58443
                        #
                        # Avantages:
                        # - URLs identiques pour tests et accès manuel (cohérence)
                        # - Plus besoin de détecter l'IP gateway
                        # - Redirect URIs OAuth2 simplifiés (pas d'IP à whitelister)
                        # - Résolution DNS stable via alias réseau Docker
                        #
                        # Note: ZAP est connecté au réseau rhdemo-ephemere-network (ligne 1117),
                        # il peut donc résoudre les alias réseau et accéder au port 58443 de nginx

                        APP_URL="https://rhdemo.ephemere.local:58443"
                        KEYCLOAK_URL="https://keycloak.ephemere.local:58443/realms/RHDemo"

                        # Credentials de test (user avec ROLE_consult + ROLE_MAJ pour tester toutes les opérations)
                        # Ces variables seront passées via propriétés Maven à TestConfig
                        # Username chargé depuis secrets-ephemere.yml (pas de valeur en dur)
                        TEST_USERNAME="\${RHDEMO_TEST_ID_USER_MAJ}"
                        TEST_PASSWORD="\${RHDEMO_TEST_PWD_USER_MAJ}"

                        # Configuration du proxy ZAP pour intercepter le trafic Selenium
                        # BaseSeleniumTest.java détecte ces variables et configure le proxy WebDriver
                        export ZAP_PROXY_HOST=owasp-zap
                        export ZAP_PROXY_PORT=8090

                        echo "📍 Configuration des tests Selenium:"
                        echo "   APP_URL: \${APP_URL}"
                        echo "   KEYCLOAK_URL: \${KEYCLOAK_URL}"
                        echo "   TEST_USERNAME: \${TEST_USERNAME} (ROLE_consult + ROLE_MAJ)"
                        echo "   Mode: Headless"
                        echo "   ZAP Proxy: \${ZAP_PROXY_HOST}:\${ZAP_PROXY_PORT}"
                        echo "   (Healthcheck HTTPS validé avant ce stage)"

                        set -x

                        # Lancement des tests avec TOUTES les configs via propriétés Maven
                        # TestConfig charge dans l'ordre: Maven properties > env vars > YAML
                        cd \${WORKSPACE}/rhDemo && ./mvnw clean test -f ../\${TEST_PROJECT_PATH}/pom.xml \\
                            -Dtest.baseurl=\${APP_URL} \\
                            -Dtest.keycloak.url=\${KEYCLOAK_URL} \\
                            -Dselenium.headless=true \\
                            -Dtest.username=\${TEST_USERNAME} \\
                            -Dtest.password=\${TEST_PASSWORD}
                    """
                }
            }
            post {
                failure {
                    script {
                        echo '📋 Échec des tests Selenium - Collecte des logs des conteneurs...'

                        sh '''
                            # Créer le répertoire pour les logs de debug
                            mkdir -p debug-logs

                            echo "📝 Collecte des logs Docker..."

                            # Logs de l'application Spring Boot (dernières 500 lignes)
                            if docker ps --format '{{.Names}}' | grep -q "rhdemo-ephemere-app"; then
                                echo "  - Application Spring Boot..."
                                docker logs rhdemo-ephemere-app --tail 500 > debug-logs/app-springboot.log 2>&1
                            fi

                            # Logs Keycloak (dernières 500 lignes)
                            if docker ps --format '{{.Names}}' | grep -q "keycloak-ephemere"; then
                                echo "  - Keycloak..."
                                docker logs keycloak-ephemere --tail 500 > debug-logs/keycloak.log 2>&1
                            fi

                            # Logs Nginx (dernières 500 lignes)
                            if docker ps --format '{{.Names}}' | grep -q "rhdemo-ephemere-nginx"; then
                                echo "  - Nginx..."
                                docker logs rhdemo-ephemere-nginx --tail 500 > debug-logs/nginx.log 2>&1
                            fi

                            # Logs ZAP (dernières 500 lignes)
                            if docker ps --format '{{.Names}}' | grep -q "rhdemo-jenkins-zap"; then
                                echo "  - OWASP ZAP..."
                                docker logs rhdemo-jenkins-zap --tail 500 > debug-logs/zap.log 2>&1
                            fi

                            # Informations réseau pour debug
                            echo "  - Configuration réseau Docker..."
                            docker network inspect rhdemo-ephemere-network > debug-logs/network-ephemere.json 2>&1 || echo "Network non trouvé" > debug-logs/network-ephemere.json
                            docker network inspect rhdemo-jenkins-network > debug-logs/network-jenkins.json 2>&1 || echo "Network non trouvé" > debug-logs/network-jenkins.json

                            # État des conteneurs
                            echo "  - État des conteneurs..."
                            docker ps -a --filter "name=ephemere" --format "table {{.Names}}\\t{{.Status}}\\t{{.Ports}}" > debug-logs/containers-status.txt

                            echo "✅ Logs collectés dans debug-logs/"
                            ls -lh debug-logs/
                        '''

                        // Archiver les logs de debug
                        archiveArtifacts artifacts: 'debug-logs/*', fingerprint: true, allowEmptyArchive: true
                    }
                }
                always {
                    script {
                        // Archiver les rapports de tests
                        junit allowEmptyResults: true, testResults: "${env.TEST_PROJECT_PATH}/target/surefire-reports/*.xml"

                        // Archiver les screenshots et DOM dumps en cas d'échec
                        archiveArtifacts artifacts: "${env.TEST_PROJECT_PATH}/target/screenshots/**/*", allowEmptyArchive: true

                        // Génération du rapport OWASP ZAP avant déconnexion
                        echo '📊 Génération du rapport OWASP ZAP...'
                        sh """#!/bin/bash
                            # Sauvegarder le workspace actuel
                            WORKSPACE_DIR=\$(pwd)

                            # Créer le répertoire pour les rapports ZAP dans le workspace
                            mkdir -p "\${WORKSPACE_DIR}/zap-reports"

                            # Utiliser la clé API ZAP définie comme variable d'environnement Jenkins
                            ZAP_API_KEY="${env.ZAP_API_KEY}"
                            ZAP_HOST="owasp-zap"
                            ZAP_PORT="8090"

                            echo "🔍 Récupération du rapport ZAP depuis http://\${ZAP_HOST}:\${ZAP_PORT}"
                            echo "   Clé API utilisée: \${ZAP_API_KEY:0:8}..."

                            # Tester d'abord la connexion à ZAP
                            if curl -s -f "http://\${ZAP_HOST}:\${ZAP_PORT}/JSON/core/view/version/?apikey=\${ZAP_API_KEY}" >/dev/null 2>&1; then
                                echo "✅ Connexion à ZAP réussie"

                                # Générer le rapport HTML
                                if curl -f -o "\${WORKSPACE_DIR}/zap-reports/zap-report.html" \
                                    "http://\${ZAP_HOST}:\${ZAP_PORT}/OTHER/core/other/htmlreport/?apikey=\${ZAP_API_KEY}" 2>&1; then
                                    echo "✅ Rapport HTML ZAP généré: \$(du -h \${WORKSPACE_DIR}/zap-reports/zap-report.html | cut -f1)"
                                else
                                    echo "⚠️  Échec de génération du rapport HTML ZAP"
                                fi

                                # Générer également le rapport JSON pour analyse
                                if curl -f -o "\${WORKSPACE_DIR}/zap-reports/zap-report.json" \
                                    "http://\${ZAP_HOST}:\${ZAP_PORT}/JSON/core/view/alerts/?apikey=\${ZAP_API_KEY}" 2>&1; then
                                    ALERT_COUNT=\$(jq '. | length' "\${WORKSPACE_DIR}/zap-reports/zap-report.json" 2>/dev/null || echo "?")
                                    echo "✅ Rapport JSON ZAP généré: \${ALERT_COUNT} alertes détectées"
                                else
                                    echo "⚠️  Échec de génération du rapport JSON ZAP"
                                fi
                            else
                                echo "❌ Impossible de se connecter à ZAP - Vérifier que ZAP est démarré et que la clé API est correcte"
                            fi
                        """

                        // Archiver les rapports ZAP
                        archiveArtifacts artifacts: 'zap-reports/*', fingerprint: true, allowEmptyArchive: true

                        // Déconnexion de ZAP du réseau ephemere après les tests
                        echo '🔌 Déconnexion de ZAP du réseau ephemere...'
                        sh '''
                            docker network disconnect rhdemo-ephemere-network rhdemo-jenkins-zap 2>/dev/null || echo "⚠️  ZAP déjà déconnecté du réseau ephemere"
                            echo "✅ ZAP déconnecté du réseau ephemere (reste sur jenkins-network)"
                        '''
                    }
                }
            }
        }

        stage('📝 Génération Rapports') {
            steps {
                script {
                    echo '▶ Publication des rapports HTML...'

                    // Charger la bibliothèque
                    def lib = load 'rhDemo/vars/rhDemoLib.groovy'

                    // Définir tous les rapports à publier
                    def reports = [
                        ['rhDemo/target/site/jacoco', 'index.html', 'Code Coverage (JaCoCo)'],
                        ['trivy-reports', 'nginx.html', 'Trivy - Nginx'],
                        ['trivy-reports', 'postgres.html', 'Trivy - PostgreSQL'],
                        ['trivy-reports', 'keycloak.html', 'Trivy - Keycloak'],
                        ['trivy-reports', 'nginx-gateway-fabric.html', 'Trivy - NGF'],
                        ['trivy-reports', 'rhdemo-app.html', 'Trivy - RHDemo App'],
                        ['rhDemo/target', 'dependency-check-report.html', 'OWASP Dependency-Check'],
                        ['zap-reports', 'zap-report.html', 'OWASP ZAP Security Report']
                    ]

                    lib.publishHTMLReports(reports)
                }
            }
        }

        // ════════════════════════════════════════════════════════════════
        // PHASE 6 : PUBLICATION DE L'IMAGE
        // ════════════════════════════════════════════════════════════════
        // NB: Jenkins utilise le socket DinD pour accéder à docker sur l'hote
        // cf docker compose de jenkins
        
        stage('🏷️ Tag et Publication Image') {
            when {
                expression { params.PUBLISH_IMAGE == true }
            }
            steps {
                script {
                    echo "▶ Tag et publication de l'image Docker sur le registry..."

                    // Déterminer le tag final avec auto-incrémentation pour SNAPSHOT
                    def baseVersion = env.APP_VERSION
                    def finalTag

                    if (baseVersion.contains('SNAPSHOT')) {
                        // Pour les SNAPSHOT : ajouter le numéro de build pour garantir l'unicité
                        finalTag = "${baseVersion}-${env.BUILD_NUMBER}${params.IMAGE_TAG_SUFFIX}"
                        echo "   Mode SNAPSHOT détecté : ajout du build number"
                        echo "   Version Maven: ${baseVersion}"
                        echo "   Build number: ${env.BUILD_NUMBER}"
                    } else {
                        // Pour les releases : utiliser la version telle quelle
                        finalTag = "${baseVersion}${params.IMAGE_TAG_SUFFIX}"
                        echo "   Mode RELEASE"
                        echo "   Version Maven: ${baseVersion}"
                    }

                    env.FINAL_IMAGE_TAG = finalTag
                    echo "   Tag final: ${finalTag}"
                }

                sh """
                    # Détecter le nom du registry
                    REGISTRY_NAME=\$(docker ps --filter "publish=5000" --format '{{.Names}}' | head -n 1)

                    if [ -z "\$REGISTRY_NAME" ]; then
                        echo "❌ Erreur: Aucun registry Docker trouvé sur le port 5000"
                        echo "   Créez d'abord un registry avec: cd rhDemo/infra/jenkins-docker && docker-compose up -d registry"
                        exit 1
                    fi

                    echo "▶ Registry détecté: \$REGISTRY_NAME"

                    # Vérifier que le registry s'appelle bien 'kind-registry'
                    if [ "\$REGISTRY_NAME" != "kind-registry" ]; then
                        echo "❌ ERREUR: Le registry s'appelle '\$REGISTRY_NAME' mais devrait s'appeler 'kind-registry'"
                        echo ""
                        echo "   Cela indique une mauvaise manipulation ou une configuration incorrecte."
                        echo "   Le nom du registry doit être standardisé."
                        echo ""
                        echo "   Pour corriger:"
                        echo "   1. docker stop \$REGISTRY_NAME && docker rm \$REGISTRY_NAME"
                        echo "   2. cd rhDemo/infra/jenkins-docker && docker-compose up -d registry"
                        echo ""
                        echo "   Voir la documentation: rhDemo/docs/REGISTRY_SETUP.md"
                        exit 1
                    fi

                    # Tag de l'image avec la version finale
                    echo "▶ Tag de l'image: ${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"
                    docker tag ${env.RHDEMO_IMAGE} ${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}

                    # Tag pour le registry (utiliser localhost:5000 depuis Jenkins)
                    echo "▶ Tag pour le registry: localhost:5000/${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"
                    docker tag ${env.RHDEMO_IMAGE} localhost:5000/${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}

                    # Push vers le registry et capturer la sortie pour extraire le digest
                    echo "▶ Push vers le registry..."
                    PUSH_OUTPUT=\$(docker push localhost:5000/${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG} 2>&1)
                    echo "\$PUSH_OUTPUT"

                    # Récupérer le digest depuis la sortie du push (format: "tag: digest: sha256:xxx size: yyy")
                    echo "▶ Récupération du digest de l'image..."
                    DIGEST=\$(echo "\$PUSH_OUTPUT" | grep -oE 'sha256:[a-f0-9]{64}' | head -1)

                    if [ -z "\$DIGEST" ]; then
                        echo "❌ Impossible de récupérer le digest de l'image"
                        exit 1
                    fi

                    echo "   Digest: \$DIGEST"

                    # Sauvegarder le digest dans un fichier pour archivage
                    mkdir -p image-digest
                    echo "\$DIGEST" > image-digest/digest.txt
                    echo "${env.FINAL_IMAGE_TAG}" > image-digest/tag.txt
                    echo "localhost:5000/${env.DOCKER_IMAGE_NAME}@\$DIGEST" > image-digest/image-ref.txt

                    echo "✅ Image publiée sur le registry:"
                    echo "   - localhost:5000/${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"
                    echo "   - Digest: \$DIGEST"
                """

                // Archiver le digest comme artefact pour le pipeline CD
                archiveArtifacts artifacts: 'image-digest/*', fingerprint: true
            }
        }

        stage('🔏 Signature Image (Cosign)') {
            when {
                allOf {
                    expression { params.PUBLISH_IMAGE == true }
                    expression { params.SIGN_IMAGE == true }
                }
            }
            steps {
                script {
                    echo "▶ Signature de l'image Docker avec Cosign..."
                    echo "   Image: localhost:5000/${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"
                }

                withCredentials([
                    file(credentialsId: 'cosign-private-key', variable: 'COSIGN_KEY'),
                    string(credentialsId: 'cosign-password', variable: 'COSIGN_PASSWORD')
                ]) {
                    sh '''
                        # Récupérer le digest de l'image pour une signature immuable
                        # Note: docker inspect utilise localhost:5000 (via Docker daemon sur l'hôte)
                        # mais cosign doit utiliser kind-registry:5000 (appels HTTPS directs depuis le conteneur Jenkins)
                        echo "▶ Récupération du digest de l'image..."
                        DIGEST=$(docker inspect --format='{{index .RepoDigests 0}}' localhost:5000/${DOCKER_IMAGE_NAME}:${FINAL_IMAGE_TAG} 2>/dev/null | sed 's|localhost:5000|kind-registry:5000|')

                        if [ -z "$DIGEST" ] || [ "$DIGEST" = "kind-registry:5000/" ]; then
                            echo "❌ Impossible de récupérer le digest via docker inspect"
                            exit 1
                        fi

                        echo "   Digest pour cosign: ${DIGEST}"

                        # Signer l'image avec Cosign
                        # Cosign fait des appels HTTPS directs, utiliser kind-registry:5000
                        # avec le certificat CA monté dans le conteneur Jenkins
                        echo "▶ Signature de l'image..."
                        SSL_CERT_FILE=/etc/ssl/certs/registry.crt \
                        COSIGN_PASSWORD="${COSIGN_PASSWORD}" cosign sign --key "${COSIGN_KEY}" \
                            "${DIGEST}"

                        echo "✅ Image signée avec succès"
                    '''
                }
            }
        }

        stage('🧹 Nettoyage Registry SNAPSHOT') {
            when {
                allOf {
                    expression { params.PUBLISH_IMAGE == true }
                    expression { env.APP_VERSION.contains('SNAPSHOT') }
                }
            }
            steps {
                script {
                    echo "▶ Nettoyage des anciennes images SNAPSHOT du registry..."
                    echo "   Politique de rétention: garder les 3 dernières versions"
                }

                sh """
                    # Configuration du registry HTTPS
                    # Note: kind-registry est accessible depuis le conteneur Jenkins via le réseau Docker
                    REGISTRY_URL="https://kind-registry:5000"
                    REGISTRY_CERT="/etc/ssl/certs/registry.crt"
                    IMAGE_NAME="${env.DOCKER_IMAGE_NAME}"
                    RETENTION_COUNT=3

                    echo "▶ Récupération de la liste des tags SNAPSHOT..."

                    # Récupérer tous les tags de l'image (avec certificat CA pour HTTPS)
                    ALL_TAGS=\$(curl -s --cacert \$REGISTRY_CERT \${REGISTRY_URL}/v2/\${IMAGE_NAME}/tags/list | jq -r '.tags[]?' 2>/dev/null || echo "")

                    if [ -z "\$ALL_TAGS" ]; then
                        echo "ℹ️  Aucun tag trouvé dans le registry"
                        exit 0
                    fi

                    # Filtrer uniquement les tags SNAPSHOT avec numéro de build
                    SNAPSHOT_TAGS=\$(echo "\$ALL_TAGS" | grep "SNAPSHOT-[0-9]" | sort -V || true)

                    if [ -z "\$SNAPSHOT_TAGS" ]; then
                        echo "ℹ️  Aucune image SNAPSHOT avec numéro de build trouvée"
                        exit 0
                    fi

                    # Compter le nombre de tags SNAPSHOT
                    TAG_COUNT=\$(echo "\$SNAPSHOT_TAGS" | wc -l)
                    echo "📊 Nombre d'images SNAPSHOT trouvées: \$TAG_COUNT"

                    if [ "\$TAG_COUNT" -le "\$RETENTION_COUNT" ]; then
                        echo "✅ Nombre d'images ≤ \$RETENTION_COUNT, aucun nettoyage nécessaire"
                        exit 0
                    fi

                    # Calculer combien d'images à supprimer
                    TO_DELETE_COUNT=\$(( TAG_COUNT - RETENTION_COUNT ))
                    echo "🗑️  Suppression des \$TO_DELETE_COUNT images les plus anciennes..."

                    # Garder seulement les N derniers tags
                    TAGS_TO_DELETE=\$(echo "\$SNAPSHOT_TAGS" | head -n \$TO_DELETE_COUNT)

                    # Supprimer les anciennes images
                    for TAG in \$TAGS_TO_DELETE; do
                        echo "  ➤ Suppression de \${IMAGE_NAME}:\${TAG}..."

                        # Récupérer le manifest avec le bon Accept header pour obtenir le digest
                        DIGEST=\$(curl -sI --cacert \$REGISTRY_CERT -H "Accept: application/vnd.docker.distribution.manifest.v2+json" \\
                            \${REGISTRY_URL}/v2/\${IMAGE_NAME}/manifests/\${TAG} \\
                            | grep -i "Docker-Content-Digest" \\
                            | awk '{print \$2}' \\
                            | tr -d '\\r')

                        if [ -n "\$DIGEST" ]; then
                            # Supprimer le manifest (cela marque l'image pour suppression)
                            HTTP_CODE=\$(curl -s --cacert \$REGISTRY_CERT -o /dev/null -w "%{http_code}" -X DELETE \\
                                \${REGISTRY_URL}/v2/\${IMAGE_NAME}/manifests/\${DIGEST})

                            if [ "\$HTTP_CODE" = "202" ] || [ "\$HTTP_CODE" = "204" ]; then
                                echo "    ✓ Tag \${TAG} marqué pour suppression (digest: \$(echo \$DIGEST | cut -c1-20)...)"
                            else
                                echo "    ⚠️  Échec suppression du tag \${TAG} (HTTP \$HTTP_CODE)"
                            fi
                        else
                            echo "    ⚠️  Impossible de récupérer le digest pour \${TAG}"
                        fi
                    done

                    echo ""
                    echo "✅ Nettoyage des tags terminé"
                    echo "📋 Images SNAPSHOT restantes:"
                    curl -s --cacert \$REGISTRY_CERT \${REGISTRY_URL}/v2/\${IMAGE_NAME}/tags/list | jq -r '.tags[]?' | grep "SNAPSHOT-[0-9]" | sort -V || echo "   (aucune)"

                    echo ""
                    echo "▶ Exécution du garbage collection du registry pour libérer l'espace disque..."

                    # Trouver le container du registry
                    # Note: Le nom 'kind-registry' a déjà été vérifié dans le stage de publication
                    REGISTRY_CONTAINER=\$(docker ps --filter "publish=5000" --format "{{.Names}}" | head -n 1)

                    if [ -z "\$REGISTRY_CONTAINER" ]; then
                        echo "⚠️  Container registry introuvable, garbage collection ignoré"
                    else
                        echo "   Registry container: \$REGISTRY_CONTAINER"

                        # Exécuter le garbage collector en mode read-only d'abord pour voir ce qui serait supprimé
                        echo "   Analyse des blobs à supprimer..."
                        BLOBS_TO_DELETE=\$(docker exec \$REGISTRY_CONTAINER registry garbage-collect --dry-run /etc/docker/registry/config.yml 2>&1 | grep -c "would delete" || echo "0")

                        if [ "\$BLOBS_TO_DELETE" -gt 0 ]; then
                            echo "   💾 \$BLOBS_TO_DELETE blob(s) seront supprimés"

                            # Exécuter le garbage collector en mode suppression réelle
                            docker exec \$REGISTRY_CONTAINER registry garbage-collect /etc/docker/registry/config.yml

                            echo "   ✅ Garbage collection terminé, espace disque libéré"
                        else
                            echo "   ℹ️  Aucun blob à supprimer"
                        fi
                    fi

                    echo ""
                    echo "✅ Nettoyage complet du registry terminé"
                """
            }
        }

        // ════════════════════════════════════════════════════════════════
        // PHASE 7 : ARCHIVAGE ET RAPPORTS
        // ════════════════════════════════════════════════════════════════

        stage('📦 Archivage Artifacts') {
            steps {
                script {
                    echo "▶ Archivage des artifacts..."
                }

                // Archiver le JAR
                archiveArtifacts artifacts: 'rhDemo/target/*.jar', fingerprint: true

                // Archiver les rapports de tests
                archiveArtifacts artifacts: 'rhDemo/target/surefire-reports/**', allowEmptyArchive: true

                // Archiver le rapport OWASP Dependency-Check
                archiveArtifacts artifacts: 'rhDemo/target/dependency-check-report.html', allowEmptyArchive: true
            }
        }

    } // fin stages

    post {
        always {
            script {
                // Charger la bibliothèque
                def lib = load 'rhDemo/vars/rhDemoLib.groovy'

                lib.printSectionHeader("Pipeline CI terminé: ${currentBuild.currentResult}")

                // Nettoyage de l'environnement ephemere
                if (!params.KEEP_EPHEMERE_ENV) {
                    echo "🧹 Nettoyage de l'environnement ephemere..."

                    // Déconnecter l'agent du réseau ephemere
                    sh """
                        AGENT_CONTAINER=\$(hostname)
                        docker network disconnect ${env.NETWORK_EPHEMERE} \$AGENT_CONTAINER 2>/dev/null || echo "⚠️  Agent déjà déconnecté"
                        echo "✅ Agent déconnecté du réseau ephemere"
                    """

                    // Arrêter et supprimer le container ZAP
                    echo "🧹 Nettoyage du container OWASP ZAP..."
                    sh """
                        docker stop rhdemo-jenkins-zap 2>/dev/null || true
                        docker rm rhdemo-jenkins-zap 2>/dev/null || true
                        echo "✅ Container ZAP supprimé"
                    """

                    dir(env.EPHEMERE_INFRA_PATH) {
                        sh """
                            # Arrêter et supprimer l'environnement Docker Compose
                            docker-compose -p ${env.COMPOSE_PROJECT_NAME} down -v 2>/dev/null || true

                            # Supprimer les containers isolés
                            docker rm -f ${env.CONTAINER_NGINX} ${env.CONTAINER_APP} ${env.CONTAINER_DB} ${env.CONTAINER_KEYCLOAK} ${env.CONTAINER_KEYCLOAK_DB} 2>/dev/null || true

                            # Supprimer l'image de build temporaire
                            docker rmi ${env.RHDEMO_IMAGE} 2>/dev/null || true
                        """
                    }

                    echo "✅ Nettoyage terminé"
                } else {
                    echo "🔧 Mode DEBUG: Environnement ephemere préservé pour tests manuels"
                    echo "⚠️  RAPPEL: L'environnement sera nettoyé au prochain build"
                    echo "📋 Containers actifs: ${env.CONTAINER_NGINX}, ${env.CONTAINER_APP}, ${env.CONTAINER_DB}, ${env.CONTAINER_KEYCLOAK}"
                    echo "🌐 URLs d'accès:"
                    echo "   - RHDemo: https://rhdemo.ephemere.local"
                    echo "   - Keycloak: https://keycloak.ephemere.local"
                }

                // Supprimer les fichiers de secrets de manière sécurisée
                lib.cleanupSecrets([
                    env.SECRETS_DECRYPTED,
                    env.SECRETS_ENV_VARS,
                    env.SECRETS_RHDEMO,
                    env.KEYCLOAK_CONFIG_TMP
                ])
                // Supprimer le répertoire temporaire isolé
                sh "rm -rf ${env.SECRETS_TMP_DIR} 2>/dev/null || true"

                echo "✅ Nettoyage terminé"
            }
        }
        success {
            script {
                echo "✅ Build réussi !"
                if (params.PUBLISH_IMAGE) {
                    echo "📦 Image publiée: ${env.DOCKER_IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"
                    echo "🚀 Prête pour le déploiement CD"
                    echo ""
                    echo "Pour déployer sur stagingkub, utilisez le pipeline Jenkinsfile-CD avec:"
                    echo "   IMAGE_TAG=${env.FINAL_IMAGE_TAG}"
                }
            }
        }
        failure {
            script {
                echo "❌ Build échoué !"
                echo "Consultez les logs pour plus de détails."
            }
        }
    }
}
