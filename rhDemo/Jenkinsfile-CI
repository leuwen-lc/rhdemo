/*
 * ═══════════════════════════════════════════════════════════════════════════
 * Pipeline CI - RHDemo
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * Pipeline d'Intégration Continue (CI) pour l'application RHDemo
 *
 * OBJECTIF :
 *   - Compiler et construire l'application (Backend + Frontend)
 *   - Exécuter les tests unitaires et d'intégration
 *   - Analyser la qualité du code (SonarQube, OWASP)
 *   - Créer l'image Docker
 *   - Tester l'application dans un environnement ephemere Docker Compose
 *   - Exécuter les tests Selenium et OWASP ZAP
 *   - Publier l'image Docker validée sur le registry
 *
 * RÉSULTAT :
 *   - Image Docker taggée et publiée : rhdemo-api:<VERSION>
 *   - Artifacts et rapports archivés
 *   - Prête pour le déploiement CD
 *
 * DÉPLOIEMENT :
 *   - Pour déployer sur Kubernetes stagingkub, utilisez le pipeline Jenkinsfile-CD
 *
 * ═══════════════════════════════════════════════════════════════════════════
 */

pipeline {
    agent { label 'builder' }

    options {
        timeout(time: 2, unit: 'HOURS')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '30', artifactNumToKeepStr: '10'))
    }

    tools {
        jdk 'JDK25'
        maven 'Maven3'
    }

    environment {
        // Configuration application
        APP_NAME = 'rhdemo-api'
        DOCKER_IMAGE_NAME = "rhdemo-api"

        // Configuration Docker
        NGINX_IMAGE = "nginx:1.29.5-alpine@sha256:1d13701a5f9f3fb01aaa88cef2344d65b6b5bf6b7d9fa4cf0dca557a8d7702ba"
        POSTGRES_IMAGE = "postgres:18.2-alpine3.22@sha256:198c924aa928fecac4bddada3bf4634430aa137a5b1fb577c0d4b6d89a2b1599"
        KEYCLOAK_IMAGE = "quay.io/keycloak/keycloak:26.5.0@sha256:24896bcb632fa37445c8ca979886f5b2370651335b92ed72724369f8e5f56b4f"
        // NGINX Gateway Fabric (stagingkub) — scanné en CI pour couverture Trivy complète
        NGF_IMAGE = "ghcr.io/nginx/nginx-gateway-fabric:2.4.0@sha256:5c40d574639b655deea77ea521032e88cc3ee19dbea0be21f8cda3368e5d9f39"

        // Configuration des tests
        TEST_PORT = '9000'
        TEST_PROJECT_PATH = 'rhDemoAPITestIHM'

        // Fichiers de secrets SOPS
        SECRETS_FILE = 'rhDemo/secrets/secrets-ephemere.yml'
        // Répertoire isolé hors workspace pour les secrets déchiffrés (sécurité)
        SECRETS_TMP_DIR   = "/tmp/rhdemo-secrets-${BUILD_NUMBER}"
        SECRETS_DECRYPTED = "/tmp/rhdemo-secrets-${BUILD_NUMBER}/secrets-decrypted.yml"
        SECRETS_ENV_VARS  = "/tmp/rhdemo-secrets-${BUILD_NUMBER}/env-vars.sh"
        SECRETS_RHDEMO    = "/tmp/rhdemo-secrets-${BUILD_NUMBER}/secrets-rhdemo.yml"
        // Config Keycloak générée hors sources (ne jamais écrire dans rhDemoInitKeycloak/src/)
        KEYCLOAK_CONFIG_TMP = "/tmp/rhdemo-secrets-${BUILD_NUMBER}/application-ephemere.yml"

        // Configuration environnement ephemere (Docker Compose)
        EPHEMERE_INFRA_PATH = 'rhDemo/infra/ephemere'
        KEYCLOAK_INIT_PATH = 'rhDemoInitKeycloak'
        TEST_DOMAIN = 'rhdemo.ephemere.local'
        KEYCLOAK_DOMAIN = 'keycloak.ephemere.local'
        COMPOSE_PROJECT_NAME = "rhdemo-ephemere-${env.BUILD_NUMBER}"

        // Noms des conteneurs Docker
        CONTAINER_NGINX = 'rhdemo-ephemere-nginx'
        CONTAINER_APP = 'rhdemo-ephemere-app'
        CONTAINER_KEYCLOAK = 'keycloak-ephemere'
        CONTAINER_KEYCLOAK_DB = 'keycloak-ephemere-db'
        CONTAINER_DB = 'rhdemo-ephemere-db'
        CONTAINER_ZAP = 'rhdemo-jenkins-zap'

        // Noms des réseaux Docker
        NETWORK_EPHEMERE = 'rhdemo-ephemere-network'
        NETWORK_JENKINS = 'rhdemo-jenkins-network'
    }

    parameters {
        booleanParam(name: 'RUN_SELENIUM_TESTS', defaultValue: true, description: 'Exécuter les tests Selenium')
        booleanParam(name: 'RUN_SONAR', defaultValue: true, description: 'Exécuter l\'analyse SonarQube')
        booleanParam(name: 'PUBLISH_IMAGE', defaultValue: true, description: 'Publier l\'image sur le registry après validation')
        booleanParam(name: 'SIGN_IMAGE', defaultValue: true, description: 'Signer l\'image Docker avec Cosign après publication')
        booleanParam(name: 'KEEP_EPHEMERE_ENV', defaultValue: false, description: 'Garder l\'environnement ephemere pour debug (ne pas nettoyer à la fin)')
        string(name: 'IMAGE_TAG_SUFFIX', defaultValue: '', description: 'Suffixe optionnel pour le tag (ex: -rc1, -hotfix)')
    }

    stages {

        // ════════════════════════════════════════════════════════════════
        // PHASE 1 : PRÉPARATION
        // ════════════════════════════════════════════════════════════════

        stage('🛠️ Checkout') {
            steps {
                script {
                    // Charger la bibliothèque
                    def lib = load 'rhDemo/vars/rhDemoLib.groovy'

                    lib.printSectionHeader("Pipeline CI - RHDemo")
                    echo "Build: #${env.BUILD_NUMBER}"
                    echo "Branch: ${env.GIT_BRANCH ?: 'N/A'}"
                    echo "═══════════════════════════════════════════════════════"
                }

                // Checkout du code
                checkout scm
                sh 'git log -1 --pretty=format:"%h - %an : %s"'

                // Purge des résidus de l'ancienne convention (fichiers générés dans le workspace)
                // Cible uniquement les fichiers générés, PAS les fichiers SOPS chiffrés versionnés
                // (secrets-ephemere.yml, secrets-stagingkub.yml sont des fichiers Git légitimes)
                // Évite que des fichiers shredés (remplis de null bytes) soient trouvés par Spring Boot
                // via optional:file:./secrets/secrets-rhdemo.yml et causent une erreur YAML (0x0)
                sh '''
                    rm -f rhDemo/secrets/secrets-rhdemo.yml 2>/dev/null || true
                    rm -f rhDemo/secrets/secrets-decrypted.yml 2>/dev/null || true
                    rm -f rhDemo/secrets/env-vars.sh 2>/dev/null || true
                    rm -f rhDemoInitKeycloak/src/main/resources/application-ephemere.yml 2>/dev/null || true
                    echo "✅ Résidus de secrets workspace nettoyés"
                '''

                script {
                    echo '▶ Vérification des projets dans le workspace...'
                    // rhDemoInitKeycloak et rhDemoAPITestIHM sont dans le MÊME repo que rhDemo
                    // Le checkout SCM récupère tout le workspace (un seul .git à la racine)
                }

                sh '''
                    echo "▶ Vérification rhDemoInitKeycloak..."
                    if [ -d "rhDemoInitKeycloak" ]; then
                        echo "✅ rhDemoInitKeycloak trouvé"
                    else
                        echo "❌ rhDemoInitKeycloak introuvable"
                        exit 1
                    fi

                    echo "▶ Vérification rhDemoAPITestIHM..."
                    if [ -d "rhDemoAPITestIHM" ]; then
                        echo "✅ rhDemoAPITestIHM trouvé"
                    else
                        echo "❌ rhDemoAPITestIHM introuvable"
                        exit 1
                    fi

                    echo ""
                    echo "✅ Tous les projets du repository sont présents"
                '''
            }
        }

        stage('🔢 Lecture Version Maven') {
            steps {
                script {
                    echo "▶ Lecture de la version depuis pom.xml..."

                    // Lire la version depuis le pom.xml avec Maven (méthode robuste)
                    env.APP_VERSION = sh(
                        script: 'cd rhDemo && ./mvnw help:evaluate -Dexpression=project.version -q -DforceStdout',
                        returnStdout: true
                    ).trim()

                    // Vérifier que la lecture a réussi
                    if (!env.APP_VERSION || env.APP_VERSION == '') {
                        error("❌ Impossible de lire la version depuis pom.xml")
                    }

                    // Construire le nom du fichier JAR avec la version lue
                    env.JAR_FILE = "rhDemo/target/rhdemoAPI-${env.APP_VERSION}.jar"

                    // Mettre à jour les variables Docker
                    env.DOCKER_IMAGE_TAG = env.APP_VERSION

                    // Construire le nom complet de l'image Docker avec version-buildnumber
                    env.RHDEMO_IMAGE = "${env.DOCKER_IMAGE_NAME}:${env.APP_VERSION}-${env.BUILD_NUMBER}"

                    echo "✅ Version Maven détectée: ${env.APP_VERSION}"
                    echo "   JAR attendu: ${env.JAR_FILE}"
                    echo "   Docker tag: ${env.DOCKER_IMAGE_TAG}"
                    echo "   Image Docker complète: ${env.RHDEMO_IMAGE}"
                }
            }
        }

        stage('🔑 Initialisation Variables Dynamiques') {
            steps {
                script {
                    echo '▶ Initialisation des variables dynamiques...'

                    // Génération d'une clé API ZAP aléatoire pour la session
                    def zapApiKey = sh(
                        script: 'cat /dev/urandom | tr -dc \'a-zA-Z0-9\' | fold -w 32 | head -n 1',
                        returnStdout: true
                    ).trim()

                    // Stocker comme variable d'environnement globale du pipeline
                    env.ZAP_API_KEY = zapApiKey
                    echo "✅ Clé API ZAP générée: ${zapApiKey.take(8)}..."
                }
            }
        }

        stage('🔓 Déchiffrement Secrets SOPS') {
            steps {
                script {
                    echo '▶ Vérification SOPS et YQ...'
                }
                sh '''
                    sops --version
                    yq --version
                '''

                script {
                    echo '▶ Déchiffrement du fichier de secrets...'
                }

                // Utiliser le credential sops-age-key de manière sécurisée
                withCredentials([file(credentialsId: 'sops-age-key', variable: 'SOPS_AGE_KEY_FILE')]) {
                    sh '''
                        # Créer le répertoire temporaire isolé hors workspace (permissions strictes)
                        mkdir -p ${SECRETS_TMP_DIR}
                        chmod 700 ${SECRETS_TMP_DIR}

                        # Déchiffrer le fichier de secrets
                        echo "Déchiffrement de ${SECRETS_FILE}..."
                        sops -d ${SECRETS_FILE} > ${SECRETS_DECRYPTED}
                        chmod 600 ${SECRETS_DECRYPTED}

                        # Vérifier que le fichier a été déchiffré
                        if [ ! -f ${SECRETS_DECRYPTED} ]; then
                            echo "❌ Échec du déchiffrement"
                            exit 1
                        fi

                        echo "✅ Secrets déchiffrés avec succès"

                        # Extraire les valeurs pour les variables d'environnement
                        # SÉCURITÉ: Désactiver l'écho des commandes pour ne pas exposer les secrets dans les logs
                        set +x

                        # Exporter les secrets comme variables d'environnement pour les stages suivants
                        # Utilisation de substitution de variables sans affichage dans stdout
                        {
                            # PROTECTION: Désactiver l'écho pour éviter l'exposition des secrets lors du sourcing
                            echo "# SÉCURITÉ: Ce fichier contient des secrets - désactive automatiquement le tracing bash"
                            echo "# Désactiver le tracing pour ne pas logger les secrets"
                            echo "{ set +x; } 2>/dev/null"
                            echo ""

                            echo "export RHDEMO_DATASOURCE_PASSWORD_PG=$(yq eval '.rhdemo.datasource.password.pg' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_DATASOURCE_PASSWORD_H2=$(yq eval '.rhdemo.datasource.password.h2' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_CLIENT_REGISTRATION_KEYCLOAK_CLIENT_SECRET=$(yq eval '.rhdemo.client.registration.keycloak.client.secret' ${SECRETS_DECRYPTED})"

                            # Mots de passe Keycloak pour environnement ephemere
                            echo "export KEYCLOAK_DB_PASSWORD=$(yq eval '.keycloak.db.password' ${SECRETS_DECRYPTED})"
                            echo "export KEYCLOAK_ADMIN_PASSWORD=$(yq eval '.keycloak.admin.password' ${SECRETS_DECRYPTED})"
                            echo "export KEYCLOAK_ADMIN_USER=$(yq eval '.keycloak.admin.user // \"admin\"' ${SECRETS_DECRYPTED})"

                            # Utilisateurs et mots de passe de test (chiffrés dans SOPS)
                            echo "export RHDEMO_TEST_ID_USER_ADMIN=$(yq eval '.rhdemo.test.iduseradmin' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_TEST_PWD_USER_ADMIN=$(yq eval '.rhdemo.test.pwduseradmin' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_TEST_ID_USER_MAJ=$(yq eval '.rhdemo.test.idusermaj' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_TEST_PWD_USER_MAJ=$(yq eval '.rhdemo.test.pwdusermaj' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_TEST_ID_USER_CONSULT=$(yq eval '.rhdemo.test.iduserconsult' ${SECRETS_DECRYPTED})"
                            echo "export RHDEMO_TEST_PWD_USER_CONSULT=$(yq eval '.rhdemo.test.pwduserconsult' ${SECRETS_DECRYPTED})"

                            # URLs des serveurs si elles existent
                            if yq eval '.rhdemo.servers.ephemere' ${SECRETS_DECRYPTED} > /dev/null 2>&1; then
                                echo "export EPHEMERE_SERVER=$(yq eval '.rhdemo.servers.ephemere' ${SECRETS_DECRYPTED})"
                            fi

                            if yq eval '.rhdemo.servers.production' ${SECRETS_DECRYPTED} > /dev/null 2>&1; then
                                echo "export PROD_SERVER=$(yq eval '.rhdemo.servers.production' ${SECRETS_DECRYPTED})"
                            fi
                        } > ${SECRETS_ENV_VARS} 2>&1
                        chmod 600 ${SECRETS_ENV_VARS}

                        # Réactiver l'écho des commandes
                        set -x

                        # Afficher (sans montrer les valeurs)
                        echo "✅ Variables d'environnement préparées dans ${SECRETS_ENV_VARS}"
                    '''
                }
            }
            post {
                always {
                    script {
                        // Supprimer le fichier déchiffré pour la sécurité
                        sh 'rm -f ${SECRETS_DECRYPTED} || true'
                    }
                }
            }
        }

        stage('🔐 Extraction secrets rhDemo') {
            steps {
                script {
                    echo '▶ Création du fichier secrets-rhdemo.yml pour rhDemo (uniquement les secrets nécessaires)...'
                }

                sh '''
                    # SÉCURITÉ: Désactiver l'écho des commandes
                    set +x

                    # Source les secrets (depuis /tmp, hors workspace)
                    . ${SECRETS_ENV_VARS}

                    # Créer un fichier secrets-rhdemo.yml contenant UNIQUEMENT les secrets rhDemo
                    # Ce fichier sera monté dans le container Docker de rhDemo
                    cat > ${SECRETS_RHDEMO} <<EOF

rhdemo:
  datasource:
    password:
      pg: ${RHDEMO_DATASOURCE_PASSWORD_PG}
      h2: ${RHDEMO_DATASOURCE_PASSWORD_H2}
  client:
    registration:
      keycloak:
        client:
          secret: ${RHDEMO_CLIENT_REGISTRATION_KEYCLOAK_CLIENT_SECRET}
EOF

                    chmod 600 ${SECRETS_RHDEMO}

                    # Réactiver l'écho
                    set -x

                    echo "✅ Fichier ${SECRETS_RHDEMO} créé hors workspace (secrets limités à rhDemo uniquement)"
                '''
            }
        }

        stage('🔧 Configuration rhDemoInitKeycloak') {
            steps {
                script {
                    echo '▶ Génération de application-ephemere.yml pour rhDemoInitKeycloak...'
                    echo '   (Sera utilisé directement via mvnw spring-boot:run, sans packaging JAR)'
                }

                sh '''
                    # Variable TEST_DOMAIN disponible via env.TEST_DOMAIN (défini dans environment block)
                    # Pas besoin de la redéfinir, elle est automatiquement accessible en bash
                    echo "🔍 TEST_DOMAIN: ${TEST_DOMAIN}"

                    # SÉCURITÉ: Désactiver l'écho des commandes pour ne pas exposer les secrets
                    set +x

                    # Source les secrets déchiffrés (depuis /tmp, hors workspace)
                    . ${SECRETS_ENV_VARS}

                    # Générer application-ephemere.yml dans /tmp (hors sources du projet)
                    # NOTE: set +x reste actif pendant la génération pour ne pas logger les secrets
                    CONFIG_FILE="${KEYCLOAK_CONFIG_TMP}"

                    # IMPORTANT: Sans guillemets sur YMLEOF pour que bash substitue les variables
                    cat > "${CONFIG_FILE}" << YMLEOF
# ========================================
# Configuration Keycloak Server - EPHEMERE
# Générée automatiquement par Jenkins CI/CD
# ========================================
keycloak:
  # URL interne HTTP pour rhDemoInitKeycloak (exécuté dans le réseau Docker)
  # Pas besoin de HTTPS car communication interne sécurisée par le réseau isolé
  server-url: http://keycloak-ephemere:8080

  admin:
    realm: master
    username: ${KEYCLOAK_ADMIN_USER}
    password: ${KEYCLOAK_ADMIN_PASSWORD}

  # ========================================
  # Configuration du Realm RHDemo
  # ========================================
  realm:
    name: RHDemo
    display-name: RHDemo Application
    enabled: true
    registration-allowed: false
    registration-email-as-username: false
    reset-password-allowed: true
    edit-username-allowed: false
    login-with-email-allowed: true
    duplicate-emails-allowed: false
    remember-me: true
    sso-session-idle-timeout: 1800
    sso-session-max-lifespan: 36000
    access-token-lifespan: 300

  # ========================================
  # Configuration du Client RHDemo
  # ========================================
  client:
    client-id: RHDemo
    name: RHDemo
    secret: ${RHDEMO_CLIENT_REGISTRATION_KEYCLOAK_CLIENT_SECRET}
    root-url: https://${TEST_DOMAIN}:58443/
    base-url: ''
    admin-url: ''
    redirect-uris:
      - https://${TEST_DOMAIN}:58443/*
      - https://rhdemo.ephemere.local:58443/*
      - https://keycloak.ephemere.local:58443/*
      - http://localhost:9000/*
    web-origins:
      - https://${TEST_DOMAIN}:58443
      - https://rhdemo.ephemere.local:58443
      - https://keycloak.ephemere.local:58443
      - http://localhost:9000
    roles:
      - ROLE_admin
      - ROLE_consult
      - ROLE_MAJ

  # ========================================
  # Configuration des Utilisateurs de test
  # ========================================
  users:
    - username: ${RHDEMO_TEST_ID_USER_ADMIN}
      password: ${RHDEMO_TEST_PWD_USER_ADMIN}
      email: ${RHDEMO_TEST_ID_USER_ADMIN}@rhdemo.local
      first-name: Admin
      last-name: RHDemo
      roles:
        - ROLE_admin

    - username: ${RHDEMO_TEST_ID_USER_CONSULT}
      password: ${RHDEMO_TEST_PWD_USER_CONSULT}
      email: ${RHDEMO_TEST_ID_USER_CONSULT}@rhdemo.local
      first-name: Jean
      last-name: Consultant
      roles:
        - ROLE_consult

    - username: ${RHDEMO_TEST_ID_USER_MAJ}
      password: ${RHDEMO_TEST_PWD_USER_MAJ}
      email: ${RHDEMO_TEST_ID_USER_MAJ}@rhdemo.local
      first-name: Marie
      last-name: Manager
      roles:
        - ROLE_consult
        - ROLE_MAJ
YMLEOF

                    chmod 600 "${CONFIG_FILE}"

                    # Réactiver l'écho maintenant que les secrets ont été écrits dans le fichier
                    set -x

                    echo "✅ Fichier de configuration Keycloak généré hors workspace: ${CONFIG_FILE}"
                    echo "   Ce fichier sera passé à rhDemoInitKeycloak via spring.config.additional-location"
                    echo "   Redirect URIs configurés pour:"
                    echo "     - https://${TEST_DOMAIN}:58443/*"
                    echo "     - https://rhdemo.ephemere.local:58443/* (pour Selenium/ZAP)"

                    echo ""
                    echo "🔍 Vérification de la section redirect-uris dans le fichier généré:"
                    grep -A 5 "redirect-uris:" "${CONFIG_FILE}" || echo "⚠️ Section redirect-uris non trouvée"
                '''
            }
        }

        // ════════════════════════════════════════════════════════════════
        // PHASE 2 : BUILD ET TESTS
        // ════════════════════════════════════════════════════════════════

        stage('🔍 Vérification Environnement') {
            steps {
                script {
                    echo '▶ Vérification de l\'environnement...'
                }

                sh '''
                    # Charger les secrets (depuis /tmp, hors workspace)
                    . ${SECRETS_ENV_VARS}

                    echo "Java version:"
                    java -version
                    echo ""
                    echo "Maven version:"
                    cd rhDemo && ./mvnw -version
                    echo ""
                    echo "Variables d'environnement:"
                    # Compter les variables RHDEMO sans afficher leurs valeurs (sécurité)
                    RHDEMO_VAR_COUNT=$(env | grep -c "^RHDEMO_" || echo "0")
                    echo "✅ $RHDEMO_VAR_COUNT variables RHDEMO configurées (valeurs masquées pour sécurité)"
                '''
            }
        }

        stage('🏗️ Compilation Maven') {
            steps {
                script {
                    echo "▶ Compilation du projet Maven..."
                }

                dir('rhDemo') {
                    sh './mvnw clean compile -DskipTests'
                }
            }
        }

        stage('✅ Tests Unitaires') {
            steps {
                script {
                    echo "▶ Exécution des tests unitaires..."
                }

                dir('rhDemo') {
                    sh './mvnw test'
                }
            }
            post {
                always {
                    junit 'rhDemo/target/surefire-reports/*.xml'
                }
            }
        }

            stage('🔍 Analyse OWASP Dependency-Check') {
                steps {
                    script {
                        echo "▶ Analyse des vulnérabilités des dépendances..."
                    }

                    dir('rhDemo') {
                        withCredentials([
                            string(credentialsId: 'nvd-api-key', variable: 'NVD_API_KEY'),
                            usernamePassword(credentialsId: 'ossindex-credentials', usernameVariable: 'OSSINDEX_USER', passwordVariable: 'OSSINDEX_PASSWORD')
                        ]) {
                            sh './mvnw org.owasp:dependency-check-maven:check -DnvdApiKey=${NVD_API_KEY} -DossindexAnalyzerUsername=${OSSINDEX_USER} -DossindexAnalyzerPassword=${OSSINDEX_PASSWORD}'
                        }
                    }
                }
                post {
                    always {
                        // Archiver le rapport OWASP
                        publishHTML([
                            allowMissing: false,
                            alwaysLinkToLastBuild: true,
                            keepAll: true,
                            reportDir: 'rhDemo/target',
                            reportFiles: 'dependency-check-report.html',
                            reportName: 'OWASP Dependency-Check Report'
                        ])
                    }
                }
            }

        stage('📦 Build Maven') {
            steps {
                script {
                    echo "▶ Build du projet (création du JAR)..."
                }

                dir('rhDemo') {
                    sh './mvnw package -DskipTests'
                }
            }
        }

        stage('📊 Analyse SonarQube') {
            when {
                expression { params.RUN_SONAR == true }
            }
            steps {
                script {
                    echo "▶ Analyse de la qualité du code avec SonarQube..."
                }

                withSonarQubeEnv('SonarQube') {
                    dir('rhDemo') {
                        sh './mvnw sonar:sonar'
                    }
                }
            }
        }

        stage('🚦 Quality Gate SonarQube') {
            when {
                expression { params.RUN_SONAR == true }
            }
            steps {
                script {
                    echo "▶ Attente du résultat Quality Gate..."
                }

                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('📈 Couverture de Code') {
            steps {
                script {
                    echo '▶ Génération du rapport de couverture JaCoCo...'
                }

                dir('rhDemo') {
                    sh './mvnw jacoco:report'
                }

                recordCoverage(
                    tools: [[parser: 'JACOCO', pattern: '**/rhDemo/target/site/jacoco/jacoco.xml']],
                    id: 'jacoco',
                    name: 'Code Coverage (JaCoCo)',
                    sourceCodeRetention: 'MODIFIED'
                )
            }
        }

        // ════════════════════════════════════════════════════════════════
        // PHASE 3 : DOCKER BUILD
        // ════════════════════════════════════════════════════════════════

        stage('🐳 Build Image Docker') {
            steps {
                script {
                    echo "▶ Construction de l'image Docker avec Dockerfile (Eclipse Temurin 21)..."
                    echo "   Version détectée: ${env.APP_VERSION}"
                    echo "   Image à construire: ${env.RHDEMO_IMAGE}"
                    echo "⚠️  Nettoyage complet: suppression de toutes les images rhdemo-api existantes..."
                }

                // Supprimer TOUTES les anciennes images rhdemo-api pour forcer reconstruction et éviter accumulation
                sh """
                    echo "📊 Images rhdemo-api avant nettoyage:"
                    docker images rhdemo-api --format "table {{.Repository}}:{{.Tag}}\\t{{.Size}}\\t{{.CreatedAt}}" || true

                    echo ""
                    echo "🧹 Suppression de toutes les images rhdemo-api..."
                    # Supprimer toutes les images avec le nom rhdemo-api (tous les tags)
                    docker images rhdemo-api -q | xargs -r docker rmi -f 2>/dev/null || echo "Aucune image rhdemo-api à supprimer"

