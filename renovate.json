{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "gitAuthor": "Renovate Bot <leuwenlc+renovate@gmail.com>",
  "baseBranchPatterns": [
    "evolutions-post-1.1.9"
  ],
  "prCreation": "immediate",
  "minimumReleaseAge": "7 days",
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": ["rhdemo-api"],
      "enabled": false
    },
    {
      "matchManagers": ["jenkins", "maven-wrapper"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Images Docker pré-épinglées par tag+digest (format non standard non détecté par les managers helm-values/dockerfile natifs) : rhDemo/infra/stagingkub/helm/rhdemo/values.yaml, rhDemo/Jenkinsfile-CI et le digest kindest/node de kind-config.yaml (Option 3 stagingkub — ce composant reste hors périmètre de la mise à jour en place, traité par reconstruction complète)",
      "managerFilePatterns": [
        "rhDemo/infra/stagingkub/helm/rhdemo/values.yaml",
        "rhDemo/Jenkinsfile-CI",
        "rhDemo/infra/stagingkub/kind-config.yaml"
      ],
      "matchStrings": [
        "(?:#|//)\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>\\S+)\\s+[A-Za-z_][\\w-]*\\s*[:=]\\s*[\"']?[^\"'\\s:]+:(?<currentValue>[^@\"'\\s]+)@(?<currentDigest>sha256:[0-9a-fA-F]+)[\"']?"
      ]
    },
    {
      "customType": "regex",
      "description": "Versions des composants d'infrastructure stagingkub (Option 3 — mise à jour en place, cf. rhDemo/docs/STAGINGKUB_REBUILD_PIPELINE.md) : Cilium, NGINX Gateway Fabric, kube-prometheus-stack, Loki, Promtail, Grafana. Format : commentaire '# renovate: datasource=... depName=... [registryUrl=...]' suivi d'une variable shell VERSION=\"x.y.z\"",
      "managerFilePatterns": [
        "rhDemo/infra/stagingkub/scripts/components/install-or-upgrade-cilium.sh",
        "rhDemo/infra/stagingkub/scripts/components/install-or-upgrade-ngf.sh",
        "rhDemo/infra/stagingkub/scripts/components/install-or-upgrade-kube-prometheus-stack.sh",
        "rhDemo/infra/stagingkub/scripts/components/install-or-upgrade-loki.sh",
        "rhDemo/infra/stagingkub/scripts/components/install-or-upgrade-promtail.sh",
        "rhDemo/infra/stagingkub/scripts/components/install-or-upgrade-grafana.sh"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s*\\n[A-Za-z_][\\w-]*=\"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
