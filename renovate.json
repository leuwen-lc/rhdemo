{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "gitAuthor": "Renovate Bot <leuwenlc+renovate@gmail.com>",
  "baseBranchPatterns": [
    "evolutions-post-1.1.8"
  ],
  "prCreation": "immediate",
  "prCreation": "immediate",
  "minimumReleaseAge": "7 days",
  "rebaseWhen": "behind-base-branch",
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": ["rhdemo-api"],
      "enabled": false
    },
    {
      "matchManagers": ["jenkins", "maven-wrapper"],
      "enabled": false
    }
  ]
}
