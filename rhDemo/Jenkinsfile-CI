        stage('🔍 Scan Sécurité Images Docker (Trivy)') {
            options {
                timeout(time: 8, unit: 'MINUTES')
            }
            steps {
                script {
                    echo "▶ Scan de sécurité des images Docker avec Trivy (parallélisé)..."
                    echo "   ℹ️  Les 4 images seront scannées en parallèle pour optimiser le temps"
                    echo ""
                    echo "   ⚠️  Le build échouera si vulnérabilités CRITICAL détectées"
                    echo "   ⏱️  Timeout: 8 minutes (au lieu de 20 min séquentiel)"

                    // Charger la bibliothèque
                    def lib = load 'rhDemo/vars/rhDemoLib.groovy'

                    // Créer le répertoire pour les rapports
                    sh 'mkdir -p trivy-reports'

                    // Télécharger/mettre à jour la base de données Trivy AVANT les scans parallèles
                    // La DB est téléchargée dans un cache partagé qui sera copié pour chaque scan
                    // Évite les conflits d'accès concurrent entre scans parallèles
                    echo "📥 Téléchargement de la base de données Trivy dans le cache partagé..."
                    sh '''
                        # Créer et utiliser le répertoire de cache partagé
                        TRIVY_CACHE_DIR="$(pwd)/.trivy-cache-shared"
                        mkdir -p "${TRIVY_CACHE_DIR}"
                        export TRIVY_CACHE_DIR

                        # Télécharger la base de vulnérabilités dans le cache partagé
                        echo "📥 Téléchargement de la base de vulnérabilités..."
                        trivy image --download-db-only 2>&1 | grep -E "(Downloading|DB Repository)" || true

                        # Télécharger la base Java DB (pour scanner rhdemo-app)
                        echo "📥 Téléchargement de la Java DB..."
                        trivy image --download-java-db-only 2>&1 | grep -E "(Downloading|DB Repository)" || true

                        echo "✅ Bases de données Trivy prêtes dans ${TRIVY_CACHE_DIR} (vuln + java)"
                        echo "   Chaque scan parallèle copiera ce cache pour éviter les conflits d'accès"
                    '''

                    // Définir les images à scanner avec leurs noms de rapports
                    def imagesToScan = [
                        [image: env.POSTGRES_IMAGE, name: 'postgres'],
                        [image: env.KEYCLOAK_IMAGE, name: 'keycloak'],
                        [image: env.NGINX_IMAGE, name: 'nginx'],
                        [image: env.NGF_IMAGE, name: 'nginx-gateway-fabric'],
                        [image: env.RHDEMO_IMAGE, name: 'rhdemo-app']
                    ]

                    echo "📋 Images à scanner:"
                    imagesToScan.each { img ->
                        echo "   - ${img.name}: ${img.image}"
                    }

                    // Créer les stages parallèles de scan
                    def scanStages = imagesToScan.collectEntries { img ->
                        ["Scan ${img.name}": {
                            lib.generateTrivyReport(img.image, img.name)
                        }]
                    }

                    // Exécuter tous les scans en parallèle
                    parallel(scanStages + [failFast: false])

                    // Agrégation des résultats et vérification des seuils
                    if (!lib.aggregateTrivyResults()) {
                        error("Trivy a détecté des vulnérabilités CRITICAL bloquantes")
                    }
                }
            }
            post {
                always {
                    // Archiver tous les rapports Trivy
                    archiveArtifacts artifacts: 'trivy-reports/**/*', allowEmptyArchive: true

                    // Publier le rapport HTML agrégé
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'trivy-reports',
                        reportFiles: 'trivy-aggregate-report.html',
                        reportName: 'Trivy Security Scan Report'
                    ])
                }
            }
        }

        stage('📦 Génération SBOM CycloneDX') {
            steps {
                script {
                    echo "▶ Génération du SBOM CycloneDX pour l'image applicative..."
                    echo "   Image: ${env.RHDEMO_IMAGE}"
                }

                sh """
                    WORKSPACE_DIR=\$(pwd)
                    mkdir -p "\${WORKSPACE_DIR}/sbom-reports"

                    # Utiliser le cache partagé Trivy (déjà préparé par le stage précédent)
                    TRIVY_CACHE_DIR="\${WORKSPACE_DIR}/.trivy-cache-shared"
                    export TRIVY_CACHE_DIR

                    echo "▶ Génération SBOM au format CycloneDX JSON..."

                    # Génération du SBOM avec Trivy
                    timeout 5m trivy image \\
                        --skip-db-update \\
                        --skip-java-db-update \\
                        --no-progress \\
                        --format cyclonedx \\
                        --output "\${WORKSPACE_DIR}/sbom-reports/rhdemo-app-sbom.json" \\
                        "${env.RHDEMO_IMAGE}" 2>&1 | grep -E "(Analyzing|Total)" || true

                    # Vérifier que le fichier a été créé et afficher les stats
                    if [ -f "\${WORKSPACE_DIR}/sbom-reports/rhdemo-app-sbom.json" ]; then
                        COMPONENT_COUNT=\$(jq '.components | length' "\${WORKSPACE_DIR}/sbom-reports/rhdemo-app-sbom.json" 2>/dev/null || echo "0")
                        SBOM_VERSION=\$(jq -r '.specVersion' "\${WORKSPACE_DIR}/sbom-reports/rhdemo-app-sbom.json" 2>/dev/null || echo "N/A")
                        echo ""
                        echo "✅ SBOM CycloneDX généré avec succès"
                        echo "   Fichier: sbom-reports/rhdemo-app-sbom.json"
                        echo "   Version CycloneDX: \${SBOM_VERSION}"
                        echo "   Nombre de composants: \${COMPONENT_COUNT}"
                    else
                        echo "⚠️  Échec de génération du SBOM"
                        # Créer un SBOM vide minimal pour éviter les erreurs d'archivage
                        echo '{"bomFormat":"CycloneDX","specVersion":"1.4","components":[]}' > "\${WORKSPACE_DIR}/sbom-reports/rhdemo-app-sbom.json"
                    fi
                """
            }
            post {
                always {
                    // Archiver le SBOM CycloneDX
                    archiveArtifacts artifacts: 'sbom-reports/**/*', allowEmptyArchive: true
                }
            }
        }

        // ════════════════════════════════════════════════════════════════
        // PHASE 5 : TESTS SELENIUM ET OWASP ZAP
